# Copie este archivo como .env.oke y reemplace todos los valores <...>.
# No confirme .env.oke: contiene credenciales.
OKE_NAMESPACE="wordpress"
OCIR_REGION_KEY="iad"
OCIR_TENANCY_NAMESPACE="<tenancy-namespace>"
OCIR_USERNAME="<domain/usuario-correo>"
OCIR_EMAIL="<correo>"
OCIR_AUTH_TOKEN="<auth-token>"

# Puede reemplazar estas rutas si las imagenes se publicaron en otro repositorio/tag.
WORDPRESS_IMAGE="iad.ocir.io/<tenancy-namespace>/demo/wordpress:1.0"
MYSQL_IMAGE="iad.ocir.io/<tenancy-namespace>/demo/mysql:1.0"

WORDPRESS_DB_NAME="wpdb"
WORDPRESS_DB_USER="wpuser"
WORDPRESS_DB_PASSWORD="wppassword"
MYSQL_ROOT_PASSWORD="rootpassword"
